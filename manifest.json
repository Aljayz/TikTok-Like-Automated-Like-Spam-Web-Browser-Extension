{
  "manifest_version": 3,
  "name": "TikTok Live Tap-Tap Spammer",
  "version": "1.0.8",
  "description": "Automatically press a key repeatedly with configurable delay and URL filter.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "super-enhanced-icon.png"
  },
  "icons": {
    "16": "super-enhanced-icon.png",
    "32": "super-enhanced-icon.png",
    "48": "super-enhanced-icon.png",
    "128": "super-enhanced-icon.png"
  }
}